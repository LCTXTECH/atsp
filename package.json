{
  "name": "@agentsentry/atsp",
  "version": "1.0.0",
  "description": "Agentic Transaction Security Protocol — open standard for AI agent on-chain governance",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "SPEC.md",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "release": "npm run prepublishOnly && npm publish --access public"
  },
  "keywords": [
    "solana",
    "elizaos",
    "ai-agents",
    "defi-security",
    "circuit-breaker",
    "agentic-capital",
    "squads-multisig",
    "typescript",
    "web3-security",
    "atsp",
    "nhi"
  ],
  "author": "AgentSentry <hello@agentsentry.net> (https://agentsentry.net)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LCTXTECH/atsp.git"
  },
  "homepage": "https://agentsentry.net/protocol/atsp",
  "bugs": {
    "url": "https://github.com/LCTXTECH/atsp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.ts"],
    "extensionsToTreatAsEsm": [],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
